                    )}
                </div>

                <div className="flex justify-between items-center mt-1">
                    {/* Dynamic QR Code */}
                    <div className="bg-white p-1 rounded border border-gray-200 shadow-sm">
                        {isReady ? (
                            <canvas ref={qrRef} width="60" height="60" style={{ width: '55px', height: '55px' }}></canvas>
                        ) : (
                            <div className="w-[55px] h-[55px] bg-gray-200 animate-pulse"></div>
                        )}
                    </div>
                    
                    {/* School Contact Info */}
                    <div className="text-right text-[8px] text-gray-600 font-bold leading-normal">
