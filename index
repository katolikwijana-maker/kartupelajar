// Helper untuk memuat library external secara dinamis
const loadScript = (src) => {
    return new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) {
            resolve();
            return;
        }
        const script = document.createElement('script');
        script.src = src;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
    });
};

// --- Sub-komponen Kartu Pelajar ---
const IdCard = ({ data, innerRef, isReady }) => {
    const barcodeRef = useRef(null);
    const qrRef = useRef(null);

    useEffect(() => {
        if (isReady) {
            const idValue = data.studentId || "0000000000"; 
            
            // Generate Barcode
            if (window.JsBarcode && barcodeRef.current) {
                try {
                    window.JsBarcode(barcodeRef.current, idValue, {
                        format: "CODE128",
                        displayValue: false, // Sembunyikan teks di bawah barcode
                        height: 30,
                        width: 2,
                        margin: 0,
                        background: "transparent",
                        lineColor: "#000"
                    });
                } catch (e) {
                    console.error("Error generate barcode:", e);
                }
            }
            
            // Generate QR Code
            if (window.QRious && qrRef.current) {
                try {
                    new window.QRious({
                        element: qrRef.current,
                        value: idValue,
                        size: 60,
                        background: 'white',
                        foreground: 'black'
                    });
                } catch (e) {
                    console.error("Error generate QR Code:", e);
                }
            }
        }
    }, [isReady, data.studentId]);

    return (
        <div 
            ref={innerRef}
            className="relative overflow-hidden bg-gray-50 flex flex-col font-sans text-gray-800 shadow-xl border border-gray-300"
            style={{
                width: '350px',
                height: '550px',
                borderRadius: '12px'
            }}
        >
            {/* Header Background Shapes */}
            <div className="absolute top-0 w-full h-[220px]" style={{ zIndex: 0 }}>
                {/* Dark Blue Triangle/Polygon */}
                <div 
                    className="absolute top-0 w-full"
                    style={{
                        height: '180px',
                        background: '#2b477b', // Biru gelap dari gambar referensi
                        clipPath: 'polygon(0 0, 100% 0, 100% 60%, 0 100%)'
                    }}
                ></div>
                {/* Light Blue Accent */}
                <div 
                    className="absolute right-0"
                    style={{
                        top: '50px',
                        width: '60%',
                        height: '130px',
                        background: '#0084c8', // Biru terang aksen
                        clipPath: 'polygon(100% 0, 100% 100%, 0 100%)',
                        zIndex: 1
                    }}
                ></div>
                
                {/* Wavy white separator (menggunakan lengkungan SVG murni) */}
                <svg className="absolute bottom-[-1px] w-full" style={{ zIndex: 2, height: '40px' }} viewBox="0 0 100 20" preserveAspectRatio="none">
                    <path d="M0,20 L0,15 Q50,-5 100,15 L100,20 Z" fill="#f9fafb" />
                    <path d="M0,15 Q50,-5 100,15" fill="none" stroke="white" strokeWidth="1.5" /> 
                </svg>
            </div>

            {/* Header Content */}
            <div className="relative z-10 flex px-4 pt-6 pb-2 text-white">
                <div className="mr-3 mt-1 shrink-0">
                    <img src={data.logoUrl} alt="Logo" className="w-12 h-12 object-contain rounded-full border-2 border-white/40 bg-white/10" crossOrigin="anonymous" />
                </div>
                {/* Vertical Divider */}
                <div className="w-[1.5px] bg-white h-12 mr-3 opacity-80 self-center"></div>
                
                <div className="flex-1 min-w-0 flex flex-col justify-center text-left">
                    <h1 className="text-[10px] font-bold tracking-wide uppercase m-0 leading-tight">Kartu Pelajar</h1>
                    <h2 className="text-xs font-bold uppercase m-0 leading-tight truncate">{data.schoolName}</h2>
                    <p className="text-[7.5px] mt-0.5 leading-tight opacity-90 break-words pr-2">
                        {data.schoolAddress} {data.schoolCity}
                    </p>
                </div>
            </div>

            {/* Photo Area */}
            <div className="relative z-10 flex justify-center mt-6">
                <div className="p-1 bg-white rounded-xl shadow-md border border-gray-100">
                    <img 
                        src={data.photoUrl} 
                        alt="Siswa" 
                        className="w-[110px] h-[140px] object-cover rounded-lg"
                        crossOrigin="anonymous"
                    />
                </div>
            </div>

            {/* Student Info Area */}
            <div className="relative z-10 text-center px-4 mt-4">
                <h2 className="text-[18px] font-bold text-[#1f4e79] uppercase tracking-wide leading-tight mb-0.5">
                    {data.studentName}
                </h2>
                <p className="text-base text-gray-700 font-semibold m-0 tracking-widest">{data.studentId}</p>
                <p className="text-xs text-gray-800 m-0 mt-0.5 uppercase font-medium">
                    {data.birthPlace}, {data.birthDate}
                </p>
            </div>

            {/* Barcode & QR Code Section */}
            <div className="relative z-10 flex flex-col px-6 mt-4">
                {/* Dynamic Barcode */}
