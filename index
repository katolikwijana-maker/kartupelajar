            <div 
                className="absolute bottom-5 left-0 z-10 flex items-center justify-start py-1.5 pl-6" 
                style={{ 
                    background: '#f59e2b',
                    width: '68%', 
                    borderTopRightRadius: '6px',
                    borderBottomRightRadius: '6px'
                }}
            >
                <span className="text-white font-extrabold tracking-[0.2em] text-[14px]">
                    {data.studentId}
                </span>
            </div>

            {/* Thin black border at very bottom */}
            <div className="absolute bottom-2 left-0 right-0 h-[2.5px] bg-gray-800 z-10 w-[90%] mx-auto"></div>
        </div>
    );
};

// --- Main App Component ---
const App = () => {
    const [cardData, setCardData] = useState(defaultData);
    const cardRef = useRef(null);
    const fileInputRef = useRef(null);
    const [isGenerating, setIsGenerating] = useState(false);
    const [errorMsg, setErrorMsg] = useState("");
    const [scriptsLoaded, setScriptsLoaded] = useState(false);

    // Load libraries on mount
    useEffect(() => {
        Promise.all([
            loadScript('https://cdnjs.cloudflare.com/ajax/libs/jsbarcode/3.11.5/JsBarcode.all.min.js'),
            loadScript('https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js'),
            loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js'),
            loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js')
        ]).then(() => {
            setScriptsLoaded(true);
        }).catch(err => {
            console.error("Gagal memuat library eksternal:", err);
            setErrorMsg("Gagal memuat komponen pembuat barcode/PDF. Silakan muat ulang halaman.");
        });
    }, []);

    // --- Handlers ---
    const handleInputChange = (e) => {
        const { name, value } = e.target;
        setCardData(prev => ({ ...prev, [name]: value }));
    };

    const handleImageUpload = (e, type) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onloadend = () => {
                setCardData(prev => ({ ...prev, [type]: reader.result }));
            };
            reader.readAsDataURL(file);
        }
    };

    const exportData = () => {
        const dataStr = JSON.stringify(cardData, null, 2);
        const blob = new Blob([dataStr], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `data_kartu_${cardData.studentName.replace(/\s+/g, '_') || 'pelajar'}.json`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    };

    const handleFileImport = (e) => {
        setErrorMsg("");
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (event) => {
            try {
                const importedData = JSON.parse(event.target.result);
                setCardData(prev => ({ ...prev, ...importedData }));
            } catch (error) {
                setErrorMsg("Format file tidak valid. Harap unggah file JSON yang sesuai.");
            }
        };
        reader.readAsText(file);
        e.target.value = null; // reset input
    };

    const triggerImport = () => {
        if (fileInputRef.current) {
            fileInputRef.current.click();
        }
    };

    const downloadPDF = async () => {
        const element = cardRef.current;
        if (!element || !window.html2canvas || !window.jspdf) {
            setErrorMsg("Library pembuatan dokumen belum siap. Silakan tunggu sebentar.");
            return;
        }
        
        setIsGenerating(true);
        setErrorMsg("");

        try {
            const canvas = await window.html2canvas(element, {
                scale: 2, // Meningkatkan resolusi render
                useCORS: true,
                backgroundColor: null
            });

            const imgData = canvas.toDataURL('image/png');
            
            // Ukuran standar kartu (CR80) dalam format mm (~ 54mm x 86mm)
            const pdf = new window.jspdf.jsPDF({
                orientation: 'portrait',
                unit: 'mm',
                format: [55, 86]
            });

            pdf.addImage(imgData, 'PNG', 0, 0, 55, 86);
            pdf.save(`Kartu_Pelajar_${cardData.studentName.replace(/\s+/g, '_')}.pdf`);
        } catch (error) {
            console.error("Gagal men-generate PDF:", error);
            setErrorMsg("Gagal membuat PDF. Pastikan gambar yang diunggah valid.");
        } finally {
            setIsGenerating(false);
        }
    };

    return (
        <div className="min-h-screen bg-gray-50 p-4 md:p-8 font-sans flex flex-col">
            <h1 className="text-3xl font-extrabold text-center mb-8 text-gray-800 tracking-tight">
                Generator Kartu Pelajar
            </h1>
            
            <div className="flex flex-col lg:flex-row gap-8 max-w-7xl mx-auto w-full">
                
                {/* --- Form Section --- */}
                <div className="flex-1 bg-white p-6 rounded-xl shadow-md border border-gray-100">
                    <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b pb-3 mb-4 gap-2">
                        <h2 className="text-xl font-semibold text-gray-700">Data Siswa & Sekolah</h2>
                        <div className="flex gap-2">
                            <button onClick={triggerImport} className="text-xs font-semibold bg-gray-100 hover:bg-gray-200 text-gray-700 py-2 px-3 rounded-lg border border-gray-300 transition flex items-center gap-1.5">
                                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                Import Data
                            </button>
                            <button onClick={exportData} className="text-xs font-semibold bg-gray-100 hover:bg-gray-200 text-gray-700 py-2 px-3 rounded-lg border border-gray-300 transition flex items-center gap-1.5">
                                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                Export Data
                            </button>
                            <input type="file" accept=".json" ref={fileInputRef} style={{ display: 'none' }} onChange={handleFileImport} />
                        </div>
                    </div>

                    {errorMsg && (
                        <div className="mb-4 p-3 bg-red-50 border border-red-200 text-red-600 rounded-lg text-sm flex justify-between items-center">
                            <span>{errorMsg}</span>
                            <button onClick={() => setErrorMsg("")} className="text-red-400 hover:text-red-600 font-bold text-lg leading-none">×</button>
                        </div>
                    )}
                    
                    <div className="space-y-4">
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">Nama Sekolah</label>
                                <input type="text" name="schoolName" value={cardData.schoolName} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                            </div>
                             <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">Logo Sekolah</label>
                                <input type="file" accept="image/*" onChange={(e) => handleImageUpload(e, 'logoUrl')} className="w-full p-1 border border-gray-300 rounded-lg text-xs text-gray-500 file:mr-3 file:py-1 file:px-2.5 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                            </div>
                        </div>

                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-1">Alamat Sekolah (Baris 1)</label>
                            <input type="text" name="schoolAddress" value={cardData.schoolAddress} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                        </div>
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-1">Alamat Sekolah (Baris 2 / Kota / Provinsi)</label>
                            <input type="text" name="schoolCity" value={cardData.schoolCity} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                        </div>

                        <hr className="my-4 border-gray-200" />

                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-1">Nama Lengkap Siswa</label>
                            <input type="text" name="studentName" value={cardData.studentName} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                        </div>
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-1">Nomor Induk / NISN</label>
                            <input type="text" name="studentId" value={cardData.studentId} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">Tempat Lahir</label>
                                <input type="text" name="birthPlace" value={cardData.birthPlace} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">Tanggal Lahir</label>
                                <input type="text" name="birthDate" value={cardData.birthDate} onChange={handleInputChange} placeholder="ex: 06 Agustus 2012" className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                            </div>
                        </div>

                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-1">Foto Siswa</label>
                            <input type="file" accept="image/*" onChange={(e) => handleImageUpload(e, 'photoUrl')} className="w-full p-1 border border-gray-300 rounded-lg text-xs text-gray-500 file:mr-3 file:py-1 file:px-2.5 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                        </div>

                         <hr className="my-4 border-gray-200" />
                         
                         <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">No. Telp / HP Sekolah</label>
                                <input type="text" name="contactNumber" value={cardData.contactNumber} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-1">Email Sekolah</label>
                                <input type="text" name="contactEmail" value={cardData.contactEmail} onChange={handleInputChange} className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                            </div>
                        </div>
                    </div>
                </div>

                {/* --- Preview Section --- */}
                <div className="flex-1 flex flex-col items-center">
                    <h2 className="text-xl font-semibold mb-4 text-gray-700 w-full text-center">Preview Kartu</h2>
                    
                    {/* The Card */}
                    <div className="mb-6 flex justify-center w-full overflow-auto p-4 bg-gray-200 rounded-2xl border border-gray-300">
                        <IdCard data={cardData} innerRef={cardRef} isReady={scriptsLoaded} />
                    </div>

                    <button 
                        onClick={downloadPDF}
                        disabled={isGenerating || !scriptsLoaded}
                        className={`font-bold py-3 px-8 rounded-full shadow-lg transition-transform transform hover:scale-105 active:scale-95 flex items-center gap-2 text-white
                            ${(isGenerating || !scriptsLoaded) ? 'bg-gray-400 cursor-not-allowed shadow-none' : 'bg-blue-600 hover:bg-blue-700'}`}
                    >
                        {isGenerating ? (
                            <span>Memproses PDF...</span>
                        ) : (
                            <>
                                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                Download PDF
                            </>
                        )}
                    </button>
                    <p className="text-xs text-gray-500 mt-3.5 text-center max-w-sm leading-relaxed">
                        *Pastikan foto berorientasi tegak (portrait 3x4). Barcode & QR code dihasilkan otomatis berdasarkan isian NISN.
                    </p>
                </div>
            </div>
        </div>
    );
};

export default App;
